// Mélodie S - Star Wars
// Version 2 buzzers uniquement
// buzzer1 = mélodie principale (fréquence haute)
// buzzer2 = basse/harmonie (fréquence basse)

void playChord2(int freq1, int freq2, int dur) {
  long startTime = millis();
  
  // Calcul de la période en microsecondes (T = 1/f)
  long period1 = 1000000L / freq1;
  long period2 = 1000000L / freq2;
  
  long lastTime1 = micros();
  long lastTime2 = micros();
  
  int state1 = LOW;
  int state2 = LOW;

  while (millis() - startTime < dur) {
    long now = micros();
    
    // Gérer le buzzer 1
    if (now - lastTime1 >= period1 / 2) {
      state1 = !state1;
      digitalWrite(buzzer1, state1);
      lastTime1 = now;
    }
    
    // Gérer le buzzer 2
    if (now - lastTime2 >= period2 / 2) {
      state2 = !state2;
      digitalWrite(buzzer2, state2);
      lastTime2 = now;
    }
  }
  digitalWrite(buzzer1, LOW);
  digitalWrite(buzzer2, LOW);
}

