<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ═══ TITRE ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌙 Contrôle Veilleuse IoT"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- ═══ BANDEAU ÉTAT ═══ -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="État: Déconnecté"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FF5252"
            android:gravity="center"
            android:background="#1A0000"
            android:layout_marginBottom="12dp"/>

        <!-- ═══ BOUTON CONNEXION ═══ -->
        <Button
            android:id="@+id/btnConnectBluetooth"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="📡  Connecter en Bluetooth"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="20dp"
            android:stateListAnimator="@null"/>

        <!-- ═══ SECTION CAPTEURS ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊  Capteurs en Temps Réel"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="14dp"/>

        <!-- 4 capteurs côte à côte -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <!-- Température -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1A1A1A"
                android:padding="10dp"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🌡️" android:textSize="28sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Température" android:textSize="11sp" android:textColor="#888888"
                    android:gravity="center" android:layout_marginTop="4dp"/>
                <TextView
                    android:id="@+id/tvTemperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°C"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FF7043"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="En attente..." android:textSize="10sp" android:textColor="#555555"
                    android:fontFamily="sans-serif-light" android:gravity="center"/>
            </LinearLayout>

            <!-- Humidité -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1A1A1A"
                android:padding="10dp"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💧" android:textSize="28sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Humidité" android:textSize="11sp" android:textColor="#888888"
                    android:gravity="center" android:layout_marginTop="4dp"/>
                <TextView
                    android:id="@+id/tvHumidity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#42A5F5"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="En attente..." android:textSize="10sp" android:textColor="#555555"
                    android:fontFamily="sans-serif-light" android:gravity="center"/>
            </LinearLayout>

            <!-- Luminosité -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1A1A1A"
                android:padding="10dp"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💡" android:textSize="28sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Luminosité" android:textSize="11sp" android:textColor="#888888"
                    android:gravity="center" android:layout_marginTop="4dp"/>
                <TextView
                    android:id="@+id/tvLight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FDD835"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="En attente..." android:textSize="10sp" android:textColor="#555555"
                    android:fontFamily="sans-serif-light" android:gravity="center"/>
            </LinearLayout>

            <!-- Son -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1A1A1A"
                android:padding="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔊" android:textSize="28sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Son" android:textSize="11sp" android:textColor="#888888"
                    android:gravity="center" android:layout_marginTop="4dp"/>
                <TextView
                    android:id="@+id/tvSound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#66BB6A"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="En attente..." android:textSize="10sp" android:textColor="#555555"
                    android:fontFamily="sans-serif-light" android:gravity="center"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Alerte temp/humidité -->
        <TextView
            android:id="@+id/tvTempAlert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginBottom="16dp"/>

        <!-- ═══ SECTION CONTRÔLES ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️  Contrôles"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#333333" android:layout_marginBottom="14dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A1A1A">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Allumage (blanc)"
                        android:textSize="15sp" android:textColor="#CCCCCC"/>
                    <Switch android:id="@+id/switchPower"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Mode automatique (capteurs)"
                        android:textSize="15sp" android:textColor="#CCCCCC"/>
                    <Switch android:id="@+id/switchAutoMode"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ SECTION COULEURS ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎨  Couleur d'éclairage"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#333333" android:layout_marginBottom="14dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button android:id="@+id/btnColorWarm"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:layout_marginEnd="6dp" android:text="Chaud" android:textSize="12sp"
                android:textColor="#000000" android:backgroundTint="#FFD54F" android:stateListAnimator="@null"/>
            <Button android:id="@+id/btnColorCool"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:layout_marginEnd="6dp" android:text="Froid" android:textSize="12sp"
                android:textColor="#000000" android:backgroundTint="#E0F7FA" android:stateListAnimator="@null"/>
            <Button android:id="@+id/btnColorRed"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:text="Rouge" android:textSize="12sp"
                android:textColor="#FFFFFF" android:backgroundTint="#E53935" android:stateListAnimator="@null"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <Button android:id="@+id/btnColorGreen"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:layout_marginEnd="6dp" android:text="Vert" android:textSize="12sp"
                android:textColor="#FFFFFF" android:backgroundTint="#43A047" android:stateListAnimator="@null"/>
            <Button android:id="@+id/btnColorBlue"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:text="Bleu" android:textSize="12sp"
                android:textColor="#FFFFFF" android:backgroundTint="#1E88E5" android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- ═══ SECTION SONS ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎵  Sons"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#333333" android:layout_marginBottom="14dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button android:id="@+id/btnMelodyP"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:layout_marginEnd="6dp" android:text="🎂 Anniv." android:textSize="11sp"
                android:textColor="#FFFFFF" android:backgroundTint="#6A1B9A" android:stateListAnimator="@null"/>
            <Button android:id="@+id/btnMelodyS"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:layout_marginEnd="6dp" android:text="⭐ Star Wars" android:textSize="11sp"
                android:textColor="#FFFFFF" android:backgroundTint="#4527A0" android:stateListAnimator="@null"/>
            <Button android:id="@+id/btnMelodyF"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:text="🎵 Fr. Jacques" android:textSize="11sp"
                android:textColor="#FFFFFF" android:backgroundTint="#283593" android:stateListAnimator="@null"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <Button android:id="@+id/btnSiren"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:layout_marginEnd="6dp" android:text="🚨 Sirène" android:textSize="13sp"
                android:textColor="#FFFFFF" android:backgroundTint="#B71C1C" android:stateListAnimator="@null"/>
            <Button android:id="@+id/btnTest"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:text="🔧 Test" android:textSize="13sp"
                android:textColor="#FFFFFF" android:backgroundTint="#37474F" android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- ═══ SECTION PROGRAMMATION ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🕐  Programmation horaire"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#333333" android:layout_marginBottom="14dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A1A1A">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <Button
                    android:id="@+id/btnAddSchedule"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="+ Ajouter une programmation"
                    android:backgroundTint="#2E7D32"
                    android:textColor="#FFFFFF"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Programmations actives :"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvScheduleList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aucune programmation"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:minHeight="36dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>